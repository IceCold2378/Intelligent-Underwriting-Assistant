# ── Intelligent Underwriting Assistant — Enterprise ──
# Copy this to .env and fill in your values

# General
APP_NAME=Intelligent Underwriting Assistant
APP_VERSION=3.0.0
ENVIRONMENT=development
DEBUG=true

# Security
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (JSON list format)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./underwriting.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/underwriting

# ── LLM Provider ──
# Options: "ollama", "openai", "azure_openai", "anthropic", "openrouter"
LLM_PROVIDER=ollama

# Ollama (local, default)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenRouter (access 100+ models via single API key)
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI (uncomment and fill if using)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# Azure OpenAI (uncomment and fill if using)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Anthropic (uncomment and fill if using)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Agent ──
AGENT_MAX_ITERATIONS=5
AGENT_ENABLE_TOOLS=true
AGENT_VERBOSE=false

# ── Vector Database ──
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=underwriting_guidelines
VECTOR_SEARCH_K=5

# ── Document Processing ──
MAX_FILE_SIZE_MB=25

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=30
